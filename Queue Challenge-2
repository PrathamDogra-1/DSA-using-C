#include <stdio.h>

#define MAX 200

int main() {
    int size;
    scanf("%d", &size);

    int arr[MAX];
    int nextGreater[MAX];
    int stack[MAX * 2];
    int top = -1;

    for (int i = 0; i < size; i++) {
        scanf("%d", &arr[i]);
        nextGreater[i] = -1;
    }

    for (int i = 0; i < 2 * size; i++) {
        int current = arr[i % size];

        while (top != -1 && arr[stack[top]] < current) {
            nextGreater[stack[top]] = current;
            top--;
        }

        if (i < size) {
            stack[++top] = i;
        }
    }

    for (int i = 0; i < size; i++) {
        if (i > 0) printf(" ");
        printf("%d", nextGreater[i]);
    }

    printf("\n");

    return 0;
}
