#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n;
    scanf("%d",&n);
    int list[n];
    for(int i=0;i<n;i++){
        scanf("%d ",&list[i]);
    }
    int value;
    scanf("%d",&value);
    for(int i=n;i>0;i--){
        list[i]=list[i-1];
    }
    n++;
    list[0]=value;
    for(int i=0;i<n;i++){
        printf("%d ",list[i]);    
        }
    return 0;
}
