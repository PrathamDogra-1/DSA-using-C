#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
#include <limits.h>
int main() {  
    int n;
    scanf("%d",&n);
    int tree[n];
    
    for(int i=0;i<n;i++){
        scanf("%d",&tree[i]);
    }
    int min=10000;
    for(int i=0;i<n;i++){
        if(tree[i]==-1)
            continue;
        if(tree[i]<min)
            min=tree[i];
    }
    printf("%d",min);
    return 0;
}
