#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
#include <ctype.h>
#define M 100
int operand[M];
int top1=-1;
void push(int value){
    operand[++top1]=value;
}
int pop(){
   return operand[top1--];
}
int evaluateprefix(char* exp){
    int len=strlen(exp);
    for(int i=len-1;i>=0;i--){
        char ch =  exp[i];
        if(isdigit(ch)){
            int num=0,place=1;
            while(isdigit(exp[i])){
                num = num+(exp[i]-'0')*place;
                place*=10;
                i--;
            }
            i++;
            push(num);
        }
        else if(ch == ' ' || ch == '\n')
            continue;
        else{
            int a =pop();
            int b= pop();
            switch(ch){
                case '+':
                    push(a+b);
                    break;
                case '-':
                    push(a-b);
                    break;
                case '*':
                    push(a*b);
                    break;
                case '/':
                    push(a/b);
                    break;
                case '^':{
                    int res=1;
                    for(int i=0;i<b;i++){
                        res*=a;
                    }
                    push(res);
                }
                    break;
            }
        }
    }
    return pop();
}
int main() {
    char exp[50];
    gets(exp);
    printf("%d\n",evaluateprefix(exp));
    return 0;
}
