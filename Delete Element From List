#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n=0,found=0;
    scanf("%d",&n);
    int list[n];
    for(int i=0;i<n;i++){
        scanf("%d ",&list[i]);
    }
    int value,pos=-1;
    scanf("%d",&value);
    for(int i=0;i<n;i++){
        if(value==list[i]){
            pos =i;
            found=1;
            break;
        }
    }
    if(found == 1){
        for(int i=pos;i<n;i++){
            list[i]=list[i+1];
        }
        n--;
        for(int i=0;i<n;i++){
            printf("%d ",list[i]);
        }
    }
    else{
        for(int i=0;i<n;i++){
            printf("%d ",list[i]);
        }
    }
    
    return 0;
}
