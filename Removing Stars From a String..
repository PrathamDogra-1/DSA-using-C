#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
#define M 100
char stack[M];
int top=-1;
void push(int value){
    stack[++top]=value;
    }
void pop(){
    top--;
}
int main() {
    char str[50];
    gets(str);
    for(int i=0;str[i]!='\0';i++){
        if(str[i]=='*'){
            pop();
        }
        else{
            push(str[i]);
        }
    }
    for(int i=0;i<=top;i++){
        printf("%c",stack[i]);
    }
    return 0;
}
