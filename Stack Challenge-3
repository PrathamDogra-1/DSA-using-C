#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n;
    scanf("%d",&n);
    int stack[n];
    for(int i = 0;i<n;i++){
        scanf("%d ",&stack[i]);
    }
    for(int i=0;i<n;i++){
        for(int j=i+1;j<n;j++){
            if(stack[j]>stack[i]){
                int temp=stack[j];
                stack[j]=stack[i];
                stack[i]=temp;
            }
        }
    }
    for(int i=0;i<n;i++){
        printf("%d ",stack[i]);
    }
    return 0;
}
