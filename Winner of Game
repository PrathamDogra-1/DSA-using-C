#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
struct node{
    int data;
    struct node* next;
};
struct node* head = NULL;
struct node* createNode(int data){
    struct node* temp=(struct node*)malloc(sizeof(struct node));
    temp->data=data;
    temp->next=NULL;
    return temp;
}
void insertatend(int data){
    struct node* newnode=createNode(data);
    if(head==NULL){
        head=newnode;
    }
    else{
        struct node* temp=head;
        while(temp->next!=NULL){
            temp=temp->next;
        }
        temp->next=newnode;
    }
}
void check(){
    struct node* temp=head;
    int even=0,odd=0,eveval=0,odval=0;
    while(temp!=NULL && temp->next!=NULL){
        eveval=temp->data;
        odval=temp->next->data;
        if(eveval>odval)
            even++;
        else if(odval>eveval)
            odd++;
        temp=temp->next->next;
    }
    if(odd>even)
        printf("Odd\n");
    else if(even>odd)
        printf("Even\n");
    else
        printf("Tie\n");
}
int main() {
    int n;
    scanf("%d",&n);
    for(int i=0;i<n;i++){
        int val;
        scanf("%d",&val);
        insertatend(val);
    }
    check();
    return 0;
}
