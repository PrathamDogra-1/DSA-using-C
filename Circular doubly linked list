#include <stdio.h>
#include <stdlib.h> 
struct node{
    int data;
    struct node* next;
    struct node* prev; 
};
struct node* head = NULL;
struct node* createnode(int data){
    struct node* temp = (struct node*)malloc(sizeof(struct node)); 
    temp->next =temp->prev= NULL;
    temp->data=data;
    return temp; 
}
void insertatend(int data){
    struct node* newnode=createnode(data);
    if(head==NULL){
        head = newnode;
        newnode->next = head; 
        newnode->prev = head; 
    }
    else{
        struct node* temp = head;
        while(temp->next!=head)
            temp=temp->next;
        newnode->prev=temp;
        temp->next = newnode;
        newnode->next = head; 
        head->prev=newnode; 
    }
}
void insertatbeg(int data){
    struct node* newnode = createnode(data); 
    if(head==NULL){
        head = newnode;
        newnode->next = head; 
        newnode->prev = head; 
    }
    else{
        struct node* temp = head;
        while(temp->next!=head)
            temp = temp->next; 
        newnode->prev = temp;
        newnode->next = head; 
        head->prev = newnode; 
        temp->next = newnode;
        head = newnode; 
    }
}
void insertatpos(int data,int pos){
    if(head==NULL){ 
        if(pos==1)
            insertatbeg(data); 
        else 
            return; 
    }
    else if(pos==1)
        insertatbeg(data); 
    else{
        struct node* temp = head; 
        int i=1;
        while(i<pos-1){
            temp=temp->next; 
            i++;
            if(temp==head)
                return; 
        } 
        struct node* newnode = createnode(data); 
        newnode->next = temp->next; 
        newnode->prev = temp; 
        temp->next->prev = newnode; 
        temp->next = newnode; 
    }
}
void delbyval(int val){ 
    struct node* temp = head;
    if(head==NULL)
        return;
    else if(temp->next==head && temp->data==val) {
        head=NULL;
    } 
    else if(temp->data==val){
        struct node* temp = head; 
        do{
            temp = temp->next; 
        }while(temp->next!=head);
        temp->next = head->next; 
        head->next->prev = temp; 
        head = head->next; 
    } 
    else{ 
        while(temp->next->data!=val){
            temp=temp->next; 
            if(temp==head)
                return;  
        }
        temp->next->next->prev = temp; 
        temp->next=temp->next->next; 
    }
}
void delfrombeg(){
    if(head==NULL)
        return;
    else if(head->next==head){
        head=NULL;
    }
    else{
        struct node* temp = head; 
        do{
            temp = temp->next; 
        }while(temp->next!=head);
        temp->next = head->next; 
        head->next->prev = temp; 
        head = head->next; 
    }
}
void delfromend(){
    if(head==NULL)
        return;
    else if(head->next==head){
        head=NULL;
    }
    else{
        struct node* temp = head;
        while(temp->next->next!=head){
            temp=temp->next; 
        }
        temp->next = head; 
        head->prev = temp; 
    }
}
void search(int data){
    int pos=1;
    struct node* temp =head; 
    int flag = 0; 
    while(temp->data!=data){
        temp=temp->next;
        pos++; 
        if(temp==head){
            flag=1;
            break; 
        }
    }
    if(flag==0)
        printf("%d\n", pos); 
    else
        printf("-1\n"); 
}
void disrev(){
    if(head==NULL)
        printf("EMPTY\n");
    else{
        struct node* temp = head;
        temp=temp->prev; 
        while(temp!=head){
            printf("%d ", temp->data); 
            temp=temp->prev; 
        } 
        printf("%d", head->data);
        printf("\n"); 
    }
}
void display(){
    if(head==NULL)
        printf("EMPTY\n");
    else{
        struct node* temp = head;
        do{
            printf("%d ", temp->data);
            temp=temp->next; 
        }while(temp!=head); 
        printf("\n"); 
    }
}
void count(){
    int count = 0; 
    if(head==NULL){
        printf("0\n");
        return;
    }
    else{
        struct node* temp = head;
        do{
            count++;
            temp=temp->next; 
        }while(temp!=head);
    }
    printf("%d\n", count); 
}
int main(){
    int q,data,pos;
    scanf("%d", &q); 
    while(q--){
        int choice;
        scanf("%d", &choice);
        switch(choice){
            case 1:
                scanf("%d", &data);
                insertatend(data);
                break;
            case 2:
                scanf("%d", &data);
                insertatbeg(data); 
                break;
            case 3:
                scanf("%d %d", &data, &pos);
                insertatpos(data,pos); 
                break;
            case 4: 
                scanf("%d", &data);
                delbyval(data); 
                break;
           case 5:
                delfrombeg();
                break;
            case 6:
                delfromend();
                break;
            case 7:
                scanf("%d", &data);
                search(data); 
                break;
            case 8:
                display();
                break;
            case 9:
                disrev(); 
                break;
            case 10: 
                count(); 
                break; 
            default:
                return 0; 
        }
    }
    return 0;
}
