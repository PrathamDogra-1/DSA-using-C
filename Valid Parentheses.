#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    char exp[100];
    gets(exp);
    char stack[100];
    int top=-1,found=0;
    for(int i=0;exp[i]!='\0';i++){
        char ch = exp[i];
        if(ch == '(' || ch == '[' || ch == '{'){
            stack[++top]=ch;
        }
        else if(ch == ')' || ch == ']' || ch == '}'){
            if(top==-1){
                found=1;
                break;
            }
            else{
                if((ch == ')' && stack[top] == '(') ||
                   (ch == ']' && stack[top] == '[') ||
                   (ch == '}' && stack[top] == '{'))
                    top--;
                else{
                    found=1;
                    break;
                }
            }
        }
    }
    if(found !=1 && top==-1){
        printf("%s is Valid",exp);
    }
    else
        printf("%s is Invalid",exp);
    
    return 0;
}
